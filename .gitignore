# IDE files
.idea/*
.fleet/*
.vscode/*
*.ctxt
.vs/*

.config/*
bin/*
.settings/*

### Java ###
*.class

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.ear

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

### Gradle ###
.gradle

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Cache of project
.gradletasknamecache

# # Work around https://youtrack.jetbrains.com/issue/IDEA-116898
# gradle/wrapper/gradle-wrapper.properties

# End of https://www.gitignore.io/api/java,gradle

# Ignore Gradle build output directory
build/*

# Ignore Python artifacts
__pycache__/
.pytest_cache/

# Ignore macOS generated files
**/.DS_Store

# DNAnalyzer runtime output (created by CLI runs)
output/
session_*/
session_*.zip

# Firebase Studio / Project IDX workspace scaffold (regenerated on demand)
.idx/

# Never commit pre-built artifacts or source archives under lib/
lib/*.jar
lib/*.war
lib/*.ear
lib/*.zip
lib/*.rar
lib/*.tar
lib/*.tar.gz
lib/*.tgz